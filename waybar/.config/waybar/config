{
    "layer": "top",
    "position": "top",
    "height": 32,
    "spacing": 8,

    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["custom/loadavg", "cpu", "memory", "network", "pulseaudio", "tray"],

    "hyprland/workspaces": {
        "all-outputs": true,
        "format": "{name}",
        "on-click": "activate",
        "sort-by-number": true
    },

    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%A, %d %B %Y | %H:%M:%S}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "format": {
                "today": "<span color='#7aa2f7'><b>{}</b></span>"
            }
        },
        "interval": 1
    },

    "custom/loadavg": {
        "exec": "awk '{printf \"%.2f\", $1}' /proc/loadavg",
        "format": "load {}",
        "interval": 5,
        "tooltip": false
    },

    "cpu": {
        "format": "cpu {usage}%",
        "interval": 2,
        "states": {
            "warning": 70,
            "critical": 90
        },
        "on-click": "kitty -e btop"
    },

    "memory": {
        "format": "mem {percentage}%",
        "format-alt": "mem {used:0.1f}G/{total:0.1f}G",
        "interval": 2,
        "states": {
            "warning": 70,
            "critical": 90
        },
        "tooltip-format": "{used:0.1f}G used of {total:0.1f}G"
    },

    "network": {
        "format-wifi": "wifi {signalStrength}%",
        "format-ethernet": "{bandwidthUpBytes} up {bandwidthDownBytes} dn",
        "format-disconnected": "offline",
        "format-alt": "{ipaddr}",
        "interval": 2,
        "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ipaddr}",
        "tooltip-format-ethernet": "{ifname}\n{ipaddr}",
        "on-click-right": "nm-connection-editor"
    },

    "pulseaudio": {
        "format": "vol {volume}%",
        "format-bluetooth": "bt {volume}%",
        "format-muted": "muted",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-",
        "tooltip-format": "{desc}"
    },

    "tray": {
        "icon-size": 16,
        "spacing": 8
    }
}
